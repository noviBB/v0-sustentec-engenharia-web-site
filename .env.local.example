# --- Supabase ------------------------------------------------------------
# Two ways to fill these:
#
# (a) LOCAL STACK — run `pnpm dev:db:up` and paste the printed `anon key`
#     and `service_role key` into the *_KEY lines below. The URLs / ports
#     below are the defaults `supabase start` exposes on 127.0.0.1.
#
#     NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
#     NEXT_PUBLIC_SUPABASE_ANON_KEY=<from `supabase start`>
#     SUPABASE_SERVICE_ROLE_KEY=<from `supabase start`>
#     DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
#     DATABASE_DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
#
# (b) HOSTED PROJECT — paste values from your Supabase dashboard
#     (Project Settings → API + Database → Connection Strings).
#
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
DATABASE_DIRECT_URL=

# Shared secret for the manual sync / cron endpoints (Authorization: Bearer <CRON_SECRET>).
CRON_SECRET=

# Notion integration token. EXTERNAL credential — may be empty in dev/CI.
# Validated LAZILY at sync time (lib/notion/client.ts), never at build/boot,
# so `pnpm build` succeeds with this empty.
NOTION_INTEGRATION_TOKEN=
